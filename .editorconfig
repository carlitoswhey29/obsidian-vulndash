root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript / JavaScript / Obsidian plugin source
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2

# JSON-style config files
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# Stylesheets
[*.{css,scss}]
indent_style = space
indent_size = 2

# Markup
[*.html]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# PowerShell
[*.ps1]
indent_style = space
indent_size = 2
end_of_line = crlf

# Windows batch files
[*.{bat,cmd}]
indent_style = tab
end_of_line = crlf

# Makefiles require tabs
[Makefile]
indent_style = tab

[makefile]
indent_style = tab
